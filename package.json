{
  "name": "sql-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-tenant SQL Agent: converts NL analytics questions into validated SQL executed against tenant-scoped MySQL databases.",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "apps/api/src/server.js",
  "scripts": {
    "start": "node apps/api/src/server.js",
    "dev": "node --watch apps/api/src/server.js",
    "lint": "tsc -p jsconfig.json --noEmit",
    "test": "find tests -name '*.test.js' -print0 | xargs -0 env PLANNER_MODE=mock SQL_MODE=mock CORRECTION_MODE=mock node --test",
    "test:validation": "node --test tests/validation/*.test.js",
    "test:execution": "node --test tests/execution/*.test.js",
    "test:orchestrator": "node --test tests/orchestrator/*.test.js",
    "seed:phase2d": "node scripts/seed-phase2d-context.js"
  },
  "dependencies": {
    "@langchain/core": "^0.3.0",
    "@langchain/langgraph": "^0.2.0",
    "@langchain/openai": "^0.3.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "langchain": "^0.3.0",
    "mongodb": "^7.2.0",
    "mysql2": "^3.11.0",
    "node-sql-parser": "^5.3.0",
    "pino": "^9.3.0",
    "pino-http": "^10.2.0",
    "redis": "^5.12.1",
    "undici": "^6.19.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "pino-pretty": "^11.2.0",
    "typescript": "^6.0.3"
  }
}
