# Server
NODE_ENV=development
PORT=4000
LOG_LEVEL=info
# Dev-only. Logs generated/corrected SQL text when NODE_ENV is not production.
DEV_LOG_GENERATED_SQL=false

# Tenant Router (control-plane). Inside the dashboard docker network this
# resolves to http://tenant-router:3004. For host-based dev, point at the
# published port.
TENANT_ROUTER_URL=http://tenant-router:3004
TENANT_ROUTER_TIMEOUT_MS=3000
# Required when tenant-router returns encrypted DB passwords shaped as
# base64(iv):base64(ciphertext). Must match dashboard PASSWORD_AES_KEY.
PASSWORD_AES_KEY=

# Tenant-router's internal-bypass header (see api-gateway auth.lua). When
# set, outgoing /tenant/resolve calls from this service carry an
# `x-pipeline-key` header so they don't need a gateway-issued JWT.
X_PIPELINE_KEY=

# Gateway trust
# Shared HMAC secret used by api-gateway to sign injected headers
# (x-gw-sig / x-gw-ts). Must match GATEWAY_SHARED_SECRET in the gateway
# deployment. When set, the middleware requires every request to carry a
# valid gateway signature.
GATEWAY_SHARED_SECRET=

# Dev escape hatch: when GATEWAY_SHARED_SECRET is unset AND this is true,
# the middleware trusts `x-brand-id` verbatim without signature checks.
# NEVER enable in production.
GATEWAY_TRUST_BYPASS=false

# Execution Defaults
EXEC_QUERY_TIMEOUT_MS=15000
EXEC_MAX_ROWS=10000
POOL_CONNECTION_LIMIT=10
POOL_IDLE_TIMEOUT_MS=600000

# LLM
# Required only when PLANNER_MODE=llm. The mocked planner needs no key.
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# Planner mode
# 'mock' (default) — deterministic plan, no LLM call.
# 'llm'  — invoke the configured LLM, return structured JSON.
# Any other value falls back to 'mock' (fail-safe).
PLANNER_MODE=mock

# SQL generator mode
# 'mock' (default) — deterministic SELECT against the gross_summary
#                    rollup table. CI-safe, no API key required.
# 'llm'  — invoke the configured LLM via getLlm("sql").invokeJson().
#          Requires OPENAI_API_KEY.
# Any other value falls back to 'mock' (fail-safe).
SQL_MODE=mock

# Correction loop mode (Phase 2C)
# 'mock' (default) — returns the failing SQL unchanged with a "mock"
#                    rationale. The next validate run will fail with
#                    the same issues; loop exits at MAX_CORRECTION_ATTEMPTS.
# 'llm'  — invoke the configured LLM via getLlm("correction").invokeJson()
#          to repair the SQL using the V_* validation issues.
# Any other value falls back to 'mock' (fail-safe).
CORRECTION_MODE=mock

# Maximum number of automated correction attempts before the request
# bails out with E_VALIDATION. Default 2. Set to 0 to disable
# correction entirely (single-shot validate).
MAX_CORRECTION_ATTEMPTS=2

# Result explanation mode (Phase 2E)
# 'mock' (default) — deterministic summary, no LLM call.
# 'llm'  — invoke the configured LLM via getLlm("explanation").invokeJson().
#          Requires OPENAI_API_KEY.
# Any other value falls back to 'mock' (fail-safe).
EXPLANATION_MODE=mock

# Phase 2D: external services for the context loader. ALL OPTIONAL —
# unset URLs trigger an in-memory fallback for that provider so the
# system still runs (with reduced grounding intelligence).

# Redis — chat memory across conversation turns.
REDIS_URL=
# Default chat-memory TTL (seconds). 24h.
CHAT_MEMORY_TTL_SECONDS=86400
# Periodic Redis→Mongo durable chat-memory sync.
CHAT_MEMORY_SYNC_INTERVAL_MS=300000
CHAT_MEMORY_SYNC_BATCH_SIZE=100

# Kafka — primary production chat-memory archive event pipeline.
KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=sql-agent
KAFKA_SSL=false
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
CHAT_MEMORY_KAFKA_ENABLED=true
CHAT_MEMORY_KAFKA_TOPIC=sql-agent.chat-memory.changed
CHAT_MEMORY_KAFKA_CONSUMER_GROUP=sql-agent-chat-memory-archive
CHAT_MEMORY_KAFKA_BATCH_SIZE=500
CHAT_MEMORY_KAFKA_FLUSH_MS=5000

# MongoDB — semantic catalog and durable chat-memory archive.
MONGO_URI=
MONGO_DB=sql_agent
MONGO_METRICS_COLLECTION=metrics
MONGO_CHAT_MEMORY_COLLECTION=chat_memory
# Default Mongo archive retention (seconds). 90d.
CHAT_MEMORY_MONGO_TTL_SECONDS=7776000

# Qdrant — vector candidate store. The HTTP REST API is used directly
# via undici; no @qdrant/js-client-rest dependency is required.
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=semantic_metrics

# Embedding model used by the vector client. Falls back to a
# deterministic SHA-256-based stub when OPENAI_API_KEY is unset.
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# How many vector candidates to fetch per request before
# round-tripping through the semantic catalog.
VECTOR_TOP_K=5
