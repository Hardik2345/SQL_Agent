# Server
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Tenant Router (control-plane). Inside the dashboard docker network this
# resolves to http://tenant-router:3004. For host-based dev, point at the
# published port.
TENANT_ROUTER_URL=http://tenant-router:3004
TENANT_ROUTER_TIMEOUT_MS=3000

# Tenant-router's internal-bypass header (see api-gateway auth.lua). When
# set, outgoing /tenant/resolve calls from this service carry an
# `x-pipeline-key` header so they don't need a gateway-issued JWT.
X_PIPELINE_KEY=

# Gateway trust
# Shared HMAC secret used by api-gateway to sign injected headers
# (x-gw-sig / x-gw-ts). Must match GATEWAY_SHARED_SECRET in the gateway
# deployment. When set, the middleware requires every request to carry a
# valid gateway signature.
GATEWAY_SHARED_SECRET=

# Dev escape hatch: when GATEWAY_SHARED_SECRET is unset AND this is true,
# the middleware trusts `x-brand-id` verbatim without signature checks.
# NEVER enable in production.
GATEWAY_TRUST_BYPASS=false

# Execution Defaults
EXEC_QUERY_TIMEOUT_MS=15000
EXEC_MAX_ROWS=10000
POOL_CONNECTION_LIMIT=10
POOL_IDLE_TIMEOUT_MS=600000

# LLM
# Required only when PLANNER_MODE=llm. The mocked planner needs no key.
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# Planner mode
# 'mock' (default) — deterministic plan, no LLM call.
# 'llm'  — invoke the configured LLM, return structured JSON.
# Any other value falls back to 'mock' (fail-safe).
PLANNER_MODE=mock

# SQL generator mode
# 'mock' (default) — deterministic SELECT against the gross_summary
#                    rollup table. CI-safe, no API key required.
# 'llm'  — invoke the configured LLM via getLlm("sql").invokeJson().
#          Requires OPENAI_API_KEY.
# Any other value falls back to 'mock' (fail-safe).
SQL_MODE=mock
